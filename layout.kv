#:kivy 2.2.1
#:import utils kivy.utils
#:import varfile varfile

<Appgrid>:
    info_label: infolabel
    text_input: input
    download_button: download_button

    canvas:
        Rectangle: #Background
            pos: self.pos
            size: self.size #(varfile.WINDOW_WIDTH, varfile.WINDOW_HEIGHT)
            texture: root.background_app

    GridLayout:
        size: root.size

        cols: 1

        padding: (0, dp(20))
        spacing: (0, dp(20))

        Image:
            size_hint_y: None
            source: varfile.TITLE_IMAGE

        Image:
            size_hint_y: None
            source: varfile.URL_LABEL_IMAGE

        BoxLayout: #URL Input & Info Label
            size_hint_y: None
            height: self.minimum_height

            orientation: "vertical"
            spacing: 10

            AnchorLayout:
                anchor_x: "center"
                anchor_y: "top"

                TextInput:
                    id: input

                    size_hint: (0.65, None)
                    height: self.font_size * 2

                    multiline: False
                    hint_text: "Insert URL here"

            AnchorLayout:
                size_hint_y: None

                anchor_x: "center"
                anchor_y: "center"

                Label:
                    id: infolabel

                    size_hint: (0.65, None)
                    height: self.texture_size[1]

                    text_size: (self.width, None)
                    halign: "center"

                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex("#1B2447")
                        Rectangle:
                            pos: self.pos
                            size: self.size
    AnchorLayout: #Download Button
        size: root.size
        anchor_x: "center"
        anchor_y: "bottom"
        padding: (0, dp(20))

        Button:
            id: download_button

            size_hint: (None, None)
            size: (dp(200), dp(100))

            text: "Download"
            on_release: root.button_click(self)
            background_normal: varfile.BTN_UP_IMAGE
            background_down: varfile.BTN_DOWN_IMAGE

    AnchorLayout: #Log Button
        size: root.size
        anchor_x: "left"
        anchor_y: "bottom"
        padding: (dp(10), dp(20))

        Button:
            id: log_button

            size_hint: (None, None)
            size: (48, 48)

            # text: "LOGS"
            on_release: root.save_log_click(self)
            background_normal: varfile.LOG_BUTTON_UP_IMAGE
            background_down: varfile.LOG_BUTTON_DOWN_IMAGE

    #[FOR DEBUG] To show rectangle around object
    #canvas.before:
        #Color:
            #rgba: (1, 0, 0, 1)
        #Line:
            #width: 2
            #rectable: self.x, self.y, self.width, self.height